# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the Python version is usually managed by the user.
#   For an app, they can be helpful to keep track of.
# .python-version

# pipenv
#   According to pypa/pipenv#1255, Pipfile.lock should be part of the code base.
#   However, in development, it's sometimes useful to ignore it.
# Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock is generally tracked, but sometimes ignored in dev.
# poetry.lock

# pdm
#   Similar to Pipenv, pdm.lock is generally tracked, but sometimes ignored in dev.
# .pdm-python
# .pdm-build/

# PEP 582; used by e.g. github.com/pypa/pdm
__pypackages__/

